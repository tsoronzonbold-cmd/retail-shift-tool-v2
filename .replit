run = "bash start.sh"
entrypoint = "app.py"
modules = ["python-3.11"]
hidden = [".pythonlibs"]

[nix]
channel = "stable-24_05"

[env]
PORT = "8080"
AWS_REGION = "us-west-2"
REDSHIFT_DB_USER = "cursor_analytics"
PYTHONUNBUFFERED = "1"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
run = ["sh", "-c", "gunicorn --bind 0.0.0.0:$PORT --workers 2 --timeout 120 app:app"]
deploymentTarget = "autoscale"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
